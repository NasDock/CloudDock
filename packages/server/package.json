{
  "name": "@cloud-dock/server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env -- tsx watch src/index.ts",
    "build": "pnpm db:generate && tsup",
    "start": "node dist/index.js",
    "db:migrate": "prisma db push --schema=./src/prisma/schema.prisma",
    "db:generate": "prisma generate --schema=./src/prisma/schema.prisma",
    "db:push": "prisma db push",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^3.1.0",
    "@cloud-dock/shared": "workspace:*",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "fastify": "^4.28.0",
    "fastify-plugin": "^4.5.0",
    "ioredis": "^5.4.0",
    "nanoid": "^5.0.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "prisma": "^5.22.0",
    "tsup": "^8.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
