{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "bundler",
    "target": "ES2022"
  },
  "include": ["src/main/**/*", "src/preload/**/*", "src/types/**/*"],
  "exclude": ["dist", "node_modules", "release"]
}
