<view class="container">
  <view class="section-desc">
    <text class="desc-text">为保障账户安全，请定期更换密码</text>
  </view>

  <view class="card">
    <view class="form-item">
      <text class="form-label">当前密码</text>
      <input
        class="form-input {{errors.oldPassword ? 'input-error' : ''}}"
        type="password"
        placeholder="请输入当前密码"
        value="{{oldPassword}}"
        bindinput="onOldPasswordInput"
      />
      <text class="error-text" wx:if="{{errors.oldPassword}}">{{errors.oldPassword}}</text>
    </view>
    <view class="divider"></view>
    <view class="form-item">
      <text class="form-label">新密码</text>
      <input
        class="form-input {{errors.newPassword ? 'input-error' : ''}}"
        type="password"
        placeholder="请输入新密码（至少8位）"
        value="{{newPassword}}"
        bindinput="onNewPasswordInput"
      />
      <text class="error-text" wx:if="{{errors.newPassword}}">{{errors.newPassword}}</text>
    </view>
    <view class="divider"></view>
    <view class="form-item">
      <text class="form-label">确认密码</text>
      <input
        class="form-input {{errors.confirmPassword ? 'input-error' : ''}}"
        type="password"
        placeholder="请再次输入新密码"
        value="{{confirmPassword}}"
        bindinput="onConfirmPasswordInput"
      />
      <text class="error-text" wx:if="{{errors.confirmPassword}}">{{errors.confirmPassword}}</text>
    </view>
  </view>

  <view class="tips">
    <text class="tips-title">密码要求</text>
    <text class="tips-item">• 长度至少8位</text>
    <text class="tips-item">• 建议包含字母和数字</text>
    <text class="tips-item">• 新密码不能与当前密码相同</text>
  </view>

  <view class="btn-section">
    <button class="btn-submit" bindtap="handleChangePassword" loading="{{loading}}">
      修改密码
    </button>
  </view>
</view>
