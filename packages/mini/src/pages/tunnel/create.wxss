.container {
  min-height: 100vh;
  background-color: #F9FAFB;
  padding: 16px;
}

.form {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.label {
  font-size: 14px;
  font-weight: 500;
  color: #374151;
}

.input {
  height: 44px;
  background-color: #FFFFFF;
  border: 1px solid #E5E7EB;
  border-radius: 8px;
  padding: 0 12px;
  font-size: 15px;
  color: #1F2937;
}

.input-error {
  border-color: #EF4444;
}

.placeholder {
  color: #9CA3AF;
}

.error-text {
  font-size: 12px;
  color: #EF4444;
}

.hint-text {
  font-size: 12px;
  color: #9CA3AF;
  margin-top: 2px;
}

.protocol-options {
  display: flex;
  gap: 8px;
}

.protocol-btn {
  flex: 1;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid #E5E7EB;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 500;
  color: #6B7280;
  background-color: #FFFFFF;
}

.protocol-btn.active {
  border-color: #6366F1;
  background-color: #EEF2FF;
  color: #6366F1;
}

.btn-primary {
  height: 44px;
  background-color: #6366F1;
  color: #FFFFFF;
  font-size: 16px;
  font-weight: 600;
  border-radius: 8px;
  margin-top: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.error-toast {
  position: fixed;
  top: 60px;
  left: 16px;
  right: 16px;
  background-color: #EF4444;
  color: #FFFFFF;
  padding: 12px 16px;
  border-radius: 8px;
  font-size: 14px;
  text-align: center;
  z-index: 1000;
}
