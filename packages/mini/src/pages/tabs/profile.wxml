<view class="container">
  <!-- Profile Header -->
  <view class="profile-card">
    <view class="profile-header">
      <view class="avatar">
        <text class="avatar-text">{{user.username ? user.username.charAt(0).toUpperCase() : 'U'}}</text>
      </view>
      <view class="profile-info">
        <text class="username">{{user.username}}</text>
        <text class="email">{{user.email}}</text>
      </view>
    </view>
    <view class="plan-badge">
      <text class="plan-text">{{getPlanLabel(user.plan)}}</text>
    </view>
  </view>

  <!-- Statistics -->
  <view class="stats-card">
    <view class="stats-item" bindtap="goToDevices">
      <text class="stats-value">{{stats.deviceOnline}}</text>
      <text class="stats-label">在线设备</text>
      <text class="stats-total">/ {{stats.deviceTotal}} 台</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item" bindtap="goToTunnels">
      <text class="stats-value">{{stats.tunnelOnline}}</text>
      <text class="stats-label">在线隧道</text>
      <text class="stats-total">/ {{stats.tunnelTotal}} 条</text>
    </view>
  </view>

  <!-- Account Info -->
  <view class="section-title-bar">
    <text class="section-title">账号信息</text>
  </view>
  <view class="card">
    <view class="info-row">
      <text class="info-label">用户ID</text>
      <text class="info-value">{{user.userId}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">注册时间</text>
      <text class="info-value">{{formatDate(user.createdAt)}}</text>
    </view>
  </view>

  <!-- Settings -->
  <view class="section-title-bar">
    <text class="section-title">设置</text>
  </view>
  <view class="card">
    <view class="list-item" bindtap="goToSettings">
      <view class="list-item-left">
        <text class="list-item-icon">⚙️</text>
        <text class="list-item-title">账户设置</text>
      </view>
      <text class="list-item-arrow">›</text>
    </view>
  </view>

  <!-- About -->
  <view class="section-title-bar">
    <text class="section-title">关于</text>
  </view>
  <view class="card">
    <view class="list-item" bindtap="goToAbout">
      <view class="list-item-left">
        <text class="list-item-icon">ℹ️</text>
        <text class="list-item-title">关于 CloudDock</text>
      </view>
      <text class="list-item-arrow">›</text>
    </view>
    <view class="divider"></view>
    <view class="list-item">
      <view class="list-item-left">
        <text class="list-item-icon">📱</text>
        <text class="list-item-title">版本信息</text>
      </view>
      <text class="list-item-desc">v1.0.0</text>
    </view>
  </view>

  <!-- Logout -->
  <view class="logout-section">
    <button class="btn-logout" bindtap="handleLogout" loading="{{loading}}">
      退出登录
    </button>
  </view>

  <view style="height: 40px;"></view>
</view>
