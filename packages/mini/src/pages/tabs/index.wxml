<view class="container">
  <!-- Header -->
  <view class="header">
    <view class="header-left">
      <text class="header-title">CloudDock</text>
      <text class="header-subtitle">{{user.username}}</text>
    </view>
    <view class="header-right">
      <view class="status-badge">
        <view class="status-dot {{onlineCount > 0 ? 'status-online' : 'status-offline'}}"></view>
        <text class="status-label">{{onlineCount}} 在线</text>
      </view>
    </view>
  </view>

  <!-- Stats -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-number">{{totalCount}}</text>
      <text class="stat-label">全部隧道</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-number stat-online">{{onlineCount}}</text>
      <text class="stat-label">在线</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-number stat-offline">{{offlineCount}}</text>
      <text class="stat-label">离线</text>
    </view>
  </view>

  <!-- Pending Devices -->
  <view class="section" wx:if="{{pendingDevices.length > 0}}">
    <view class="section-header">
      <text class="section-title">需要审批的设备</text>
      <text class="see-all" bindtap="goToDevices">去处理</text>
    </view>
    <view class="card">
      <view class="pending-item" wx:for="{{pendingDevices}}" wx:key="deviceId" wx:for-item="device">
        <text class="pending-name">{{device.name || '未知设备'}}</text>
        <text class="pending-meta">{{device.platform || 'unknown'}}</text>
      </view>
      <text class="pending-more" wx:if="{{pendingDevices.length > 3}}">
        还有 {{pendingDevices.length - 3}} 台设备待审批
      </text>
    </view>
  </view>

  <!-- Recent Tunnels -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">最近隧道</text>
      <text class="see-all" bindtap="goToTunnels">查看全部</text>
    </view>

    <view wx:if="{{recentTunnels.length === 0}}">
      <view class="card empty-card">
        <text class="empty-title">暂无隧道</text>
        <text class="empty-subtitle">创建你的第一个隧道来暴露本地服务</text>
      </view>
    </view>

    <view class="tunnel-list">
      <view
        class="tunnel-card"
        wx:for="{{recentTunnels}}"
        wx:key="tunnelId"
        bindtap="goToTunnelDetail"
        data-tunnel-id="{{item.tunnelId}}"
      >
        <view class="tunnel-header">
          <text class="tunnel-name">{{item.name}}</text>
          <view class="tunnel-status-dot {{item.status === 'online' ? 'online' : 'offline'}}"></view>
        </view>
        <text class="tunnel-url">{{getPublicUrl(item.publicPath)}}</text>
        <view class="tunnel-footer">
          <text class="tunnel-device">{{item.clientId ? clientNames[item.clientId] || '默认设备' : '默认设备'}}</text>
          <text class="tunnel-protocol">{{item.protocol.toUpperCase()}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Account Card -->
  <view class="section">
    <view class="account-card" bindtap="goToDevices">
      <view class="account-info">
        <view class="avatar">
          <text class="avatar-text">{{user.username ? user.username.charAt(0).toUpperCase() : 'U'}}</text>
        </view>
        <view class="account-detail">
          <text class="account-name">{{user.username}}</text>
          <text class="account-email">{{user.email}}</text>
        </view>
      </view>
      <text class="chevron">›</text>
    </view>
  </view>

  <view style="height: 100px;"></view>

  <!-- FAB -->
  <view class="fab" bindtap="goToTunnelCreate">
    <text class="fab-text">+</text>
  </view>
</view>
