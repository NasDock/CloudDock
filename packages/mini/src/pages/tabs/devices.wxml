<view class="container">
  <!-- Tab Switcher -->
  <view class="tab-switcher">
    <view
      class="tab-btn {{activeTab === 'access' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="access"
    >
      访问控制
    </view>
    <view
      class="tab-btn {{activeTab === 'clients' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="clients"
    >
      客户端
    </view>
  </view>

  <!-- Clients Tab -->
  <view wx:if="{{activeTab === 'clients'}}">
    <view class="list-content">
      <view
        class="device-card"
        wx:for="{{clients}}"
        wx:key="clientId"
        wx:for-item="client"
      >
        <view class="card-header">
          <text class="device-name">{{client.name}}</text>
          <view class="device-status-badge {{client.enabled === false ? 'offline' : client.status}}">
            <view class="status-dot"></view>
            <text>{{client.enabled === false ? '已下线' : client.status === 'online' ? '在线' : '离线'}}</text>
          </view>
        </view>
        <view class="card-info-row">
          <text class="info-label">设备ID</text>
          <text class="info-value">{{client.clientId}}</text>
        </view>
        <view class="card-info-row" wx:if="{{client.lastSeen}}">
          <text class="info-label">最后在线</text>
          <text class="info-value">{{formatRelativeTime(client.lastSeen)}}</text>
        </view>
        <view class="card-actions">
          <view class="action-btn" bindtap="openRename" data-client="{{client}}">
            <text>重命名</text>
          </view>
          <view class="action-btn" bindtap="handleToggleStatus" data-client="{{client}}">
            <text>{{client.enabled === false ? '上线' : '下线'}}</text>
          </view>
          <view class="action-btn action-delete" bindtap="handleUnbind" data-client="{{client}}">
            <text>解绑</text>
          </view>
        </view>
      </view>

      <view class="empty-state" wx:if="{{clients.length === 0 && !loading}}">
        <text class="empty-title">暂无 NAS 设备</text>
        <text class="empty-subtitle">使用移动端扫码绑定 NAS 设备</text>
      </view>
    </view>
  </view>

  <!-- Access Control Tab -->
  <view wx:if="{{activeTab === 'access'}}">
    <!-- Auto Approve Setting -->
    <view class="settings-card">
      <view class="settings-row">
        <view class="settings-info">
          <text class="settings-title">新设备自动放行</text>
          <text class="settings-desc">开启后，新设备首次访问会直接放行；关闭后，需要在防火墙页面手动审批后才会转发。</text>
        </view>
        <switch
          checked="{{requestDeviceSettings.autoApproveNewRequestDevices}}"
          bindchange="handleAutoApproveToggle"
          color="#6366F1"
        />
      </view>
    </view>

    <view class="list-content">
      <view
        class="device-card"
        wx:for="{{requestDevices}}"
        wx:key="requestDeviceId"
        wx:for-item="device"
      >
        <view class="card-header">
          <text class="device-name">{{device.name || '未知设备'}}</text>
          <view class="device-status-badge {{device.status === 'approved' ? 'online' : 'offline'}}">
            <text>{{device.status === 'approved' ? '已允许' : device.status === 'blocked' ? '已禁止' : '待审批'}}</text>
          </view>
        </view>
        <view class="card-info-row">
          <text class="info-label">设备ID</text>
          <text class="info-value">{{device.requestDeviceId}}</text>
        </view>
        <view class="card-info-row" wx:if="{{device.platform}}">
          <text class="info-label">平台</text>
          <text class="info-value">{{device.platform}}</text>
        </view>
        <view class="card-info-row" wx:if="{{device.lastSeen}}">
          <text class="info-label">最近访问</text>
          <text class="info-value">{{formatRelativeTime(device.lastSeen)}}</text>
        </view>
        <view class="card-actions">
          <view
            wx:if="{{device.status !== 'approved'}}"
            class="action-btn"
            bindtap="handleRequestDevice"
            data-device="{{device}}"
            data-action="approved"
          >
            <text>允许</text>
          </view>
          <view
            wx:if="{{device.status !== 'blocked'}}"
            class="action-btn"
            bindtap="handleRequestDevice"
            data-device="{{device}}"
            data-action="blocked"
          >
            <text>禁止</text>
          </view>
          <view
            class="action-btn action-delete"
            bindtap="handleRequestDeviceRemove"
            data-device="{{device}}"
          >
            <text>删除</text>
          </view>
        </view>
      </view>

      <view class="empty-state" wx:if="{{requestDevices.length === 0 && !loading}}">
        <text class="empty-title">暂无访问设备</text>
        <text class="empty-subtitle">{{requestDeviceSettings.autoApproveNewRequestDevices ? '新设备会默认自动放行' : '新设备需要审批后才可访问'}}</text>
      </view>
    </view>
  </view>

  <view style="height: 100px;"></view>

  <!-- FAB -->
  <view class="fab" bindtap="goToScan">
    <text class="fab-icon">⊕</text>
    <text class="fab-label">扫码绑定</text>
  </view>

  <!-- Rename Dialog -->
  <view class="dialog-mask" wx:if="{{dialogVisible}}" bindtap="closeDialog">
    <view class="dialog" catchtap="">
      <text class="dialog-title">修改设备名称</text>
      <input
        class="dialog-input"
        value="{{renameValue}}"
        bindinput="onRenameInput"
        placeholder="请输入设备名称"
        focus
      />
      <view class="dialog-actions">
        <view class="dialog-btn" bindtap="closeDialog">
          <text>取消</text>
        </view>
        <view class="dialog-btn dialog-btn-primary" bindtap="confirmRename">
          <text>保存</text>
        </view>
      </view>
    </view>
  </view>
</view>
