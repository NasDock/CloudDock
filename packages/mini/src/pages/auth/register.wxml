<view class="container">
  <view class="header">
    <text class="title">创建账号</text>
    <text class="subtitle">加入 CloudDock</text>
  </view>

  <view class="form">
    <view class="form-item">
      <text class="label">用户名</text>
      <input
        class="input {{errors.username ? 'input-error' : ''}}"
        value="{{username}}"
        bindinput="onUsernameInput"
        placeholder="请输入用户名"
        placeholder-class="placeholder"
        adjust-position
      />
      <text class="error-text" wx:if="{{errors.username}}">{{errors.username}}</text>
    </view>

    <view class="form-item">
      <text class="label">邮箱</text>
      <input
        class="input {{errors.email ? 'input-error' : ''}}"
        value="{{email}}"
        bindinput="onEmailInput"
        placeholder="your@email.com"
        placeholder-class="placeholder"
        type="email"
        adjust-position
      />
      <text class="error-text" wx:if="{{errors.email}}">{{errors.email}}</text>
    </view>

    <view class="form-item">
      <text class="label">密码</text>
      <input
        class="input {{errors.password ? 'input-error' : ''}}"
        value="{{password}}"
        bindinput="onPasswordInput"
        placeholder="至少6个字符"
        placeholder-class="placeholder"
        password
        adjust-position
      />
      <text class="error-text" wx:if="{{errors.password}}">{{errors.password}}</text>
    </view>

    <view class="form-item">
      <text class="label">确认密码</text>
      <input
        class="input {{errors.confirmPassword ? 'input-error' : ''}}"
        value="{{confirmPassword}}"
        bindinput="onConfirmPasswordInput"
        placeholder="再次输入密码"
        placeholder-class="placeholder"
        password
        adjust-position
      />
      <text class="error-text" wx:if="{{errors.confirmPassword}}">{{errors.confirmPassword}}</text>
    </view>

    <button
      class="btn-primary"
      bindtap="handleRegister"
      loading="{{loading}}"
      disabled="{{loading}}"
    >
      注册
    </button>

    <button class="btn-outline" bindtap="goToLogin" disabled="{{loading}}">
      已有账号？去登录
    </button>
  </view>

  <view class="error-toast" wx:if="{{globalError}}">
    <text>{{globalError}}</text>
  </view>
</view>
