/* pages/device/signal.wxss */

.container {
  min-height: 100vh;
  background-color: #0F0F0F;
  padding: 16px;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

/* Session Header */
.session-header {
  display: flex;
  flex-direction: row;
  gap: 12px;
}
.session-info {
  flex: 1;
  background-color: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 10px;
  padding: 12px 16px;
}
.label {
  font-size: 11px;
  color: rgba(255, 255, 255, 0.4);
  display: block;
  margin-bottom: 4px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.value {
  font-size: 15px;
  font-weight: 600;
  color: #FFFFFF;
  display: block;
  word-break: break-all;
}
.role-caller {
  color: #818CF8;
}
.role-callee {
  color: #34D399;
}

/* Status Section */
.status-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}
.status-badge {
  padding: 8px 24px;
  border-radius: 20px;
  font-size: 14px;
  font-weight: 600;
}
.status-badge.idle {
  background-color: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.15);
}
.status-badge.connecting {
  background-color: rgba(99, 102, 241, 0.2);
  color: #818CF8;
  border: 1px solid rgba(99, 102, 241, 0.4);
}
.status-badge.waiting_answer {
  background-color: rgba(234, 179, 8, 0.2);
  color: #FACC15;
  border: 1px solid rgba(234, 179, 8, 0.4);
}
.status-badge.connected {
  background-color: rgba(16, 185, 129, 0.2);
  color: #34D399;
  border: 1px solid rgba(16, 185, 129, 0.4);
}
.status-badge.failed {
  background-color: rgba(239, 68, 68, 0.2);
  color: #F87171;
  border: 1px solid rgba(239, 68, 68, 0.4);
}
.status-badge.closed {
  background-color: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.4);
  border: 1px solid rgba(255, 255, 255, 0.15);
}
.error-msg {
  background-color: rgba(239, 68, 68, 0.15);
  border: 1px solid rgba(239, 68, 68, 0.3);
  border-radius: 8px;
  padding: 8px 12px;
  max-width: 100%;
}
.error-msg text {
  font-size: 12px;
  color: #F87171;
}

/* Sections */
.section {
  background-color: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 12px;
  padding: 16px;
}
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}
.section-title {
  font-size: 13px;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.7);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.section-count {
  font-size: 12px;
  background-color: rgba(99, 102, 241, 0.25);
  color: #818CF8;
  padding: 2px 8px;
  border-radius: 10px;
}

/* ICE List */
.ice-list {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.ice-item {
  display: flex;
  flex-direction: row;
  gap: 8px;
  background-color: rgba(255, 255, 255, 0.04);
  border-radius: 6px;
  padding: 8px;
  align-items: flex-start;
}
.ice-index {
  font-size: 11px;
  color: rgba(255, 255, 255, 0.3);
  min-width: 20px;
}
.ice-content {
  font-size: 11px;
  color: rgba(255, 255, 255, 0.5);
  word-break: break-all;
  font-family: monospace;
}

/* SDP Items */
.sdp-item {
  margin-bottom: 8px;
}
.sdp-label {
  font-size: 11px;
  color: rgba(255, 255, 255, 0.4);
  display: block;
  margin-bottom: 4px;
}
.sdp-preview {
  font-size: 11px;
  color: rgba(255, 255, 255, 0.6);
  word-break: break-all;
  font-family: monospace;
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 6px;
  padding: 8px;
  display: block;
  max-height: 80px;
  overflow: hidden;
}
.btn-copy {
  background-color: rgba(99, 102, 241, 0.2);
  color: #818CF8;
  border: 1px solid rgba(99, 102, 241, 0.3);
  border-radius: 6px;
  font-size: 12px;
  padding: 2px 10px;
}

/* Manual Panel */
.manual-panel {
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.input-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.input-label {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.5);
}
.sdp-textarea {
  width: 100%;
  min-height: 80px;
  background-color: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 8px;
  padding: 10px;
  font-size: 12px;
  color: #FFFFFF;
  font-family: monospace;
  box-sizing: border-box;
  line-height: 18px;
}
.btn-row {
  display: flex;
  flex-direction: row;
  gap: 8px;
}
.btn-action {
  height: 36px;
  background-color: #6366F1;
  color: #FFFFFF;
  font-size: 13px;
  font-weight: 600;
  border-radius: 8px;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
}
.btn-action.secondary {
  background-color: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.8);
  border: 1px solid rgba(255, 255, 255, 0.15);
}
.btn-toggle {
  background-color: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.7);
  border: 1px solid rgba(255, 255, 255, 0.15);
  border-radius: 6px;
  font-size: 12px;
  padding: 2px 10px;
}

/* Bottom Actions */
.actions {
  margin-top: auto;
  padding-top: 8px;
}
.btn-primary {
  width: 100%;
  height: 48px;
  background-color: #6366F1;
  color: #FFFFFF;
  font-size: 16px;
  font-weight: 600;
  border-radius: 12px;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-danger {
  width: 100%;
  height: 48px;
  background-color: rgba(239, 68, 68, 0.15);
  color: #F87171;
  font-size: 16px;
  font-weight: 600;
  border-radius: 12px;
  border: 1px solid rgba(239, 68, 68, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Toast */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: rgba(0, 0, 0, 0.8);
  color: #FFFFFF;
  padding: 12px 24px;
  border-radius: 8px;
  font-size: 14px;
  z-index: 9999;
  max-width: 280px;
  text-align: center;
  pointer-events: none;
}
