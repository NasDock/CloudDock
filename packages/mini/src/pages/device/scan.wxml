<view class="container">
  <!-- Permission Request -->
  <view class="centered" wx:if="{{!hasCameraPermission && !permissionLoading}}">
    <text class="message">需要相机权限来扫描二维码</text>
    <button class="btn-primary" bindtap="requestPermission">授予权限</button>
  </view>

  <view class="centered" wx:if="{{permissionLoading}}">
    <text class="message">请求相机权限中...</text>
  </view>

  <!-- Camera -->
  <view class="camera-wrap" wx:if="{{hasCameraPermission}}">
    <camera
      device-position="back"
      flash="off"
      bindscancode="onScanSuccess"
      style="width: 100%; height: 100%;"
    />

    <!-- Scan Overlay -->
    <view class="scan-overlay">
      <view class="scan-area">
        <view class="corner top-left"></view>
        <view class="corner top-right"></view>
        <view class="corner bottom-left"></view>
        <view class="corner bottom-right"></view>
      </view>
    </view>
  </view>

  <!-- Instructions -->
  <view class="instructions">
    <view class="instructions-card">
      <text class="instructions-title">扫码说明</text>
      <text class="instructions-text">
        1. 在 NAS 管理界面生成绑定二维码\n
        2. 将二维码对准相机\n
        3. 确认绑定请求
      </text>
    </view>
  </view>

  <!-- Rescan Button -->
  <view class="rescan-wrap" wx:if="{{scanned && !binding}}">
    <button class="btn-rescan" bindtap="handleRescan">重新扫描</button>
  </view>

  <!-- Binding Loading -->
  <view class="loading-overlay" wx:if="{{binding}}">
    <view class="loading-box">
      <text class="loading-text">绑定中...</text>
    </view>
  </view>

  <!-- Toast -->
  <view class="toast" wx:if="{{toastVisible}}">
    <text>{{toastText}}</text>
  </view>
</view>
