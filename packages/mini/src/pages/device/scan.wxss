/* pages/device/scan.wxss */

.container {
  min-height: 100vh;
  background-color: #0F0F0F;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.state-panel {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32px 24px;
  box-sizing: border-box;
  gap: 12px;
}

/* Icons */
.icon-wrap {
  margin-bottom: 8px;
}
.icon {
  font-size: 56px;
}
.icon-large {
  font-size: 64px;
}

/* Typography */
.title {
  font-size: 22px;
  font-weight: 700;
  color: #FFFFFF;
  text-align: center;
}
.subtitle {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.6);
  text-align: center;
  line-height: 22px;
  white-space: pre-line;
}

/* Buttons */
.btn-primary {
  width: 100%;
  max-width: 320px;
  height: 48px;
  background-color: #6366F1;
  color: #FFFFFF;
  font-size: 16px;
  font-weight: 600;
  border-radius: 12px;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 8px;
}
.btn-primary:active {
  opacity: 0.85;
}

.btn-secondary {
  width: 100%;
  max-width: 320px;
  height: 44px;
  background-color: rgba(255, 255, 255, 0.1);
  color: #FFFFFF;
  font-size: 15px;
  font-weight: 500;
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 8px;
}

.btn-scan {
  width: 100%;
  max-width: 280px;
  height: 56px;
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  color: #FFFFFF;
  font-size: 18px;
  font-weight: 700;
  border-radius: 28px;
  border: none;
  box-shadow: 0 4px 20px rgba(99, 102, 241, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Scan mode */
.scan-mode {
  justify-content: flex-start;
  padding-top: 24px;
}
.scan-header {
  text-align: center;
  margin-bottom: 16px;
}
.scan-header .title {
  font-size: 20px;
}
.scan-header .subtitle {
  margin-top: 6px;
}

/* Camera Preview */
.camera-preview {
  width: 260px;
  height: 260px;
  background-color: #1A1A2E;
  border-radius: 16px;
  position: relative;
  overflow: hidden;
  border: 2px solid rgba(99, 102, 241, 0.3);
  margin: 8px 0;
}
.camera-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
}
.placeholder-text {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.4);
  text-align: center;
  line-height: 20px;
  white-space: pre-line;
}

/* Scan Frame */
.scan-frame {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 180px;
  height: 180px;
}
.corner {
  position: absolute;
  width: 32px;
  height: 32px;
  border-color: #6366F1;
}
.top-left {
  top: 0; left: 0;
  border-top-width: 3px;
  border-left-width: 3px;
  border-top-left-radius: 6px;
}
.top-right {
  top: 0; right: 0;
  border-top-width: 3px;
  border-right-width: 3px;
  border-top-right-radius: 6px;
}
.bottom-left {
  bottom: 0; left: 0;
  border-bottom-width: 3px;
  border-left-width: 3px;
  border-bottom-left-radius: 6px;
}
.bottom-right {
  bottom: 0; right: 0;
  border-bottom-width: 3px;
  border-right-width: 3px;
  border-bottom-right-radius: 6px;
}
.scan-line {
  position: absolute;
  top: 0;
  left: 8px;
  right: 8px;
  height: 2px;
  background: linear-gradient(90deg, transparent, #6366F1, transparent);
  animation: scanMove 2s ease-in-out infinite;
}
@keyframes scanMove {
  0% { top: 0; }
  50% { top: calc(100% - 2px); }
  100% { top: 0; }
}

.scan-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 20px;
  gap: 8px;
}

/* Help Card */
.help-card {
  width: 100%;
  max-width: 320px;
  background-color: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 12px;
  padding: 16px;
  margin-top: 16px;
}
.help-title {
  font-size: 13px;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.7);
  display: block;
  margin-bottom: 8px;
}
.help-text {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.4);
  line-height: 20px;
  white-space: pre-line;
}

/* Status Badge */
.status-badge {
  padding: 6px 16px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 600;
  margin-top: 8px;
}
.status-badge.connecting {
  background-color: rgba(99, 102, 241, 0.2);
  color: #818CF8;
  border: 1px solid rgba(99, 102, 241, 0.4);
}
.status-badge.connected {
  background-color: rgba(16, 185, 129, 0.2);
  color: #34D399;
  border: 1px solid rgba(16, 185, 129, 0.4);
}
.status-badge.failed {
  background-color: rgba(239, 68, 68, 0.2);
  color: #F87171;
  border: 1px solid rgba(239, 68, 68, 0.4);
}
.status-badge.idle {
  background-color: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.6);
  border: 1px solid rgba(255, 255, 255, 0.2);
}

/* Action Group */
.action-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  margin-top: 12px;
  width: 100%;
  max-width: 280px;
}

/* Spinner */
.spinner {
  width: 40px;
  height: 40px;
  border: 3px solid rgba(99, 102, 241, 0.2);
  border-top-color: #6366F1;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 8px auto;
}
.spinner-row {
  display: flex;
  justify-content: center;
  margin-top: 8px;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}

/* Result mode */
.result-mode {
  gap: 10px;
}

/* Success mode */
.success-mode {
  background: radial-gradient(ellipse at center, #0F1F0F 0%, #0F0F0F 100%);
}

/* Error mode */
.error-mode {
  background: radial-gradient(ellipse at center, #1F0F0F 0%, #0F0F0F 100%);
}

/* Toast */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: rgba(0, 0, 0, 0.8);
  color: #FFFFFF;
  padding: 12px 24px;
  border-radius: 8px;
  font-size: 14px;
  z-index: 9999;
  max-width: 280px;
  text-align: center;
  pointer-events: none;
}
